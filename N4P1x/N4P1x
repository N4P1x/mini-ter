#!/bin/bash

TF="$HOME/.config/N4P1x/.current-theme"
SYNC="$HOME/.config/hypr/scripts/theme/sync-all"

if [[ -d "$HOME/.config/N4P1x/$1" && "$1" != "list" && "$1" != "info" && "$1" != "sync" && "$1" != "current" && "$1" != "i" ]]; then
    echo "$1" > "$TF"
    $SYNC
    exit $?
fi

case "${1:-}" in
    l|list)
        ls -d "$HOME/.config/N4P1x"/*/ | xargs -n1 basename | grep -v "hooks\|current" | sort
        ;;
    i|info|current)
        cat "$TF" 2>/dev/null || echo "dynamic"
        ;;
    s|switch)
        shift
        echo "${1:-dynamic}" > "$TF"
        $SYNC
        ;;
    sync)
        $SYNC
        ;;
    help|--help|-h|"")
        echo "N4P1x"
        echo ""
        echo "Usage: N4P1x <theme>"
        echo "       N4P1x list"
        echo "       N4P1x sync"
        echo ""
        echo "Themes:"
        ls -d "$HOME/.config/N4P1x"/*/ | xargs -n1 basename | grep -v "hooks\|current" | sort | sed 's/^/  /'
        ;;
esac
