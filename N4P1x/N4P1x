#!/bin/bash

source "$(dirname "$(readlink -f "$0")")/env.sh"

if [[ -d "$N4P1X_DIR/$1" && "$1" != "list" && "$1" != "info" && "$1" != "sync" && "$1" != "current" && "$1" != "i" ]]; then
    echo "$1" > "$N4P1X_CURRENT_THEME"
    "$N4P1X_SYNC_SCRIPT"
    exit $?
fi

case "${1:-}" in
    l|list)
        ls -d "$N4P1X_DIR"/*/ | xargs -n1 basename | grep -v "hooks\|current" | sort
        ;;
    i|info|current)
        cat "$N4P1X_CURRENT_THEME" 2>/dev/null || echo "dynamic"
        ;;
    s|switch)
        shift
        echo "${1:-dynamic}" > "$N4P1X_CURRENT_THEME"
        "$N4P1X_SYNC_SCRIPT"
        ;;
    sync)
        "$N4P1X_SYNC_SCRIPT"
        ;;
    help|--help|-h|"")
        echo "N4P1x"
        echo ""
        echo "Usage: N4P1x <theme>"
        echo "       N4P1x list"
        echo "       N4P1x sync"
        echo ""
        echo "Themes:"
        ls -d "$N4P1X_DIR"/*/ | xargs -n1 basename | grep -v "hooks\|current" | sort | sed 's/^/  /'
        ;;
esac
