#!/bin/bash
set -euo pipefail

# Source shared utilities (also loads env.sh via common.sh)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$SCRIPT_DIR/../../hypr/scripts/lib/common.sh" 2>/dev/null || true

# Cooldown lock
if ! mkdir "$N4P1X_WALL_LOCK" 2>/dev/null; then exit 0; fi

COOLDOWN_MS=900
update_stamp() { date +%s%3N 2>/dev/null > "$N4P1X_WALL_STAMP" || echo "$(( $(date +%s) * 1000 ))" > "$N4P1X_WALL_STAMP"; }
trap 'update_stamp; rmdir "$N4P1X_WALL_LOCK" 2>/dev/null || true' EXIT
now_ms="$(date +%s%3N 2>/dev/null || echo "$(( $(date +%s) * 1000 ))")"
last_ms="$(cat "$N4P1X_WALL_STAMP" 2>/dev/null || echo 0)"
if [[ "$last_ms" =~ ^[0-9]+$ ]] && (( now_ms - last_ms < COOLDOWN_MS )); then exit 0; fi
echo "$now_ms" > "$N4P1X_WALL_STAMP"

wallbin=$(get_wallbin 2>/dev/null || true)
[[ -z "$wallbin" ]] && { notify-send "No wallpaper daemon" "Install swww or awww" "critical"; exit 1; }

wallpaper_dir="$N4P1X_BG_DIR"
[[ -d "$N4P1X_BG_DIR_FALLBACK" ]] && wallpaper_dir="$N4P1X_BG_DIR_FALLBACK"
wallpaper_params="--transition-fps 60 --transition-type grow --transition-duration 0.45 --transition-bezier 0.25,0.1,0.25,1.0 --transition-pos top-right"

mapfile -d '' wallpapers < <(find "$wallpaper_dir" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.gif" -o -iname "*.webp" \) -print0)

[[ ${#wallpapers[@]} -eq 0 ]] && {
	notify-send -A "open=Get Wallpapers" --wait "No Wallpapers" "Add to ~/Pictures/Wallpapers"
	exit 1
}

menu() {
	for wp in "${wallpapers[@]}"; do
		printf "%s\x00icon\x1f%s\n" "$(basename "$wp")" "$wp"
	done | sort
}

ensure_wallpaper_daemon &>/dev/null || true

choice=$(menu | rofi -i -dmenu -p "" -config ~/.config/rofi/custom-rofi/config-wallpaper.rasi)
[[ -z "$choice" ]] && exit 0

for wp in "${wallpapers[@]}"; do
	[[ "$(basename "$wp")" == "$choice" ]] || continue
	"$wallbin" img "$wp" $wallpaper_params >/dev/null 2>&1 &
	mkdir -p "$(dirname "$N4P1X_CURRENT_WALL")"
	cp -f "$wp" "$N4P1X_CURRENT_WALL" 2>/dev/null || true

	(
		if command -v matugen >/dev/null 2>&1 && mkdir "$N4P1X_MATUGEN_LOCK" 2>/dev/null; then
			trap "rmdir '$N4P1X_MATUGEN_LOCK' 2>/dev/null || true" EXIT
			matugen image "$wp" -c "$N4P1X_MATUGEN_CONFIG" --quiet --prefer saturation
		fi
		N4P1X_SKIP_WALLPAPER=1 N4P1X_FAST_SYNC=1 "$N4P1X_SYNC_SCRIPT"
	) &>/dev/null &

	notify-send -i "$wp" "Dynamic" "Colors from wallpaper"
	break
done
