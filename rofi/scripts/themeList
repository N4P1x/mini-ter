#!/bin/bash
THEMES_DIR="$HOME/.config/N4P1x"
CURRENT=$(cat "$THEMES_DIR/.current-theme" 2>/dev/null)

SELECTED=$(ls -d "$THEMES_DIR"/*/ | xargs -n1 basename | grep -v "current\|hooks\|base\|dynamic" | sort | \
    rofi -dmenu -i -p "Theme" -config ~/.config/rofi/config.rasi)

[[ -z "$SELECTED" ]] && exit 0
[[ "$SELECTED" == "$CURRENT" ]] && exit 0

N4P1x switch "$SELECTED"
