#!/bin/bash
set -euo pipefail

STATE_FILE="/tmp/focus-mode-state"
ws_id=$(hyprctl activeworkspace -j 2>/dev/null | jq -r .id)
gaps=$(hyprctl workspacerules -j 2>/dev/null | jq -r ".[] | select(.workspaceString == \"$ws_id\") | .gapsOut[0] // 0")

if [[ "$gaps" == "0" ]]; then
    hyprctl keyword "workspace $ws_id, gapsout:10, gapsin:4, bordersize:2" decoration:rounding 15 animations:enabled true 2>/dev/null
    sed -i 's/background_opacity 1$/background_opacity 0.65/g' ~/.config/kitty/kitty.conf
    pkill -SIGUSR1 -x kitty 2>/dev/null || true
    ~/.config/hypr/scripts/restart-app waybar
    rm -f "$STATE_FILE"
    notify-send "Vibe Mode"
else
    hyprctl keyword "workspace $ws_id, gapsout:0, gapsin:0, bordersize:1" decoration:rounding 0 animations:enabled false 2>/dev/null
    sed -i 's/background_opacity 0\.65$/background_opacity 1/g' ~/.config/kitty/kitty.conf
    pkill -SIGUSR1 -x kitty 2>/dev/null || true
    pkill -x waybar 2>/dev/null || true
    touch "$STATE_FILE"
    notify-send "Focus Mode"
fi
