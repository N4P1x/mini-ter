#!/bin/bash

source "${BASH_SOURCE[0]%/*}/../../../N4P1x/env.sh"

THEME=$(cat "$N4P1X_CURRENT_THEME" 2>/dev/null || echo "dynamic")
GREEN='\033[0;32m'; RED='\033[0;31m'; YEL='\033[1;33m'; RESET='\033[0m'

echo "Theme: $THEME"
echo ""

chk() { [[ -f "$1" ]] && echo -e "${GREEN}✓${RESET} $2" || echo -e "${RED}✗${RESET} $2"; }

chk "$HOME/.config/gtk-3.0/gtk.css" "GTK3"
chk "$HOME/.config/gtk-4.0/gtk.css" "GTK4"
chk "$HOME/.config/waybar/colors.css" "Waybar"
chk "$HOME/.config/waybar/style.css" "Waybar style"
chk "$HOME/.config/rofi/config.rasi" "Rofi"
chk "$HOME/.config/mako/colors" "Mako"
chk "$HOME/.config/swaync/matugen/colors.css" "SwayNC"
chk "$HOME/.config/hypr/theme/colors.conf" "Hyprland"
chk "$HOME/.config/alacritty/colors.toml" "Alacritty"
chk "$HOME/.config/kitty/colors.conf" "Kitty"
chk "$HOME/.config/ghostty/theme" "Ghostty"
chk "$HOME/.config/starship.toml" "Starship"
chk "$HOME/.config/btop/themes/current.theme" "Btop"
chk "$HOME/.config/cava/config" "Cava"
chk "$HOME/.config/yazi/theme.toml" "Yazi"
chk "$HOME/.config/vesktop/themes/N4P1x-discord.css" "Vesktop"

echo ""
echo -e "${YEL}Colors:${RESET}"
for f in gtk-3.0/gtk.css waybar/colors.css mako/colors swaync/matugen/colors.css; do
  p="$HOME/.config/$f"
  [[ -f "$p" ]] && echo "  $f: $(head -1 "$p" | tr -d '\n')"
done