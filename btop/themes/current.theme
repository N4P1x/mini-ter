# Matugen template for btop
# Styled to match other catbug0x1 themes


# Colors should be in 6 or 2 character hexadecimal or single spaced rgb decimal: "#RRGGBB", "#BW" or "0-255 0-255 0-255"
# example for white: "#ffffff", "#ff" or "255 255 255".

# All graphs and meters can be gradients
# For single color graphs leave "mid" and "end" variable empty.
# Use "start" and "end" variables for two color gradient
# Use "start", "mid" and "end" for three color gradient

# Main background, empty for terminal default, need to be empty if you want transparent background
theme[main_bg]=""

# Main text color
theme[main_fg]="#ebe1d4"

# Title color for boxes - accent color
theme[title]="#ebc16c"

# Highlight color for keyboard shortcuts - accent color
theme[hi_fg]="#ebc16c"

# Background color of selected item in processes box - muted surface, not vibrant
theme[selected_bg]="#241f17"

# Foreground color of selected item in processes box - normal foreground
theme[selected_fg]="#ebe1d4"

# Color of inactive/disabled text
theme[inactive_fg]="#9a8f80"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#b1cfa8"

# Cpu box outline color - subtle
theme[cpu_box]="#4d4639"

# Memory/disks box outline color
theme[mem_box]="#4d4639"

# Net up/down box outline color
theme[net_box]="#4d4639"

# Processes box outline color
theme[proc_box]="#4d4639"

# Box divider line and small boxes line color
theme[div_line]="#4d4639"

# Temperature graph colors
theme[temp_start]="#b1cfa8"
theme[temp_mid]="#ebc16c"
theme[temp_end]="#ffb4ab"

# CPU graph colors
theme[cpu_start]="#ebc16c"
theme[cpu_mid]="#d9c4a0"
theme[cpu_end]="#b1cfa8"

# Mem/Disk free meter
theme[free_start]="#b1cfa8"
theme[free_mid]=""
theme[free_end]="#b1cfa8"

# Mem/Disk cached meter
theme[cached_start]="#d9c4a0"
theme[cached_mid]=""
theme[cached_end]="#d9c4a0"

# Mem/Disk available meter
theme[available_start]="#ebc16c"
theme[available_mid]=""
theme[available_end]="#ebc16c"

# Mem/Disk used meter
theme[used_start]="#ffb4ab"
theme[used_mid]=""
theme[used_end]="#ffb4ab"

# Download graph colors
theme[download_start]="#b1cfa8"
theme[download_mid]="#ebc16c"
theme[download_end]="#d9c4a0"

# Upload graph colors
theme[upload_start]="#d9c4a0"
theme[upload_mid]="#ebc16c"
theme[upload_end]="#b1cfa8"

# Process box color gradient for threads, mem and cpu usage
theme[process_start]="#b1cfa8"
theme[process_mid]="#ebc16c"
theme[process_end]="#ffb4ab"
