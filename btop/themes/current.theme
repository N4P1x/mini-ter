# Matugen template for btop
# Styled to match other catbug0x1 themes


# Colors should be in 6 or 2 character hexadecimal or single spaced rgb decimal: "#RRGGBB", "#BW" or "0-255 0-255 0-255"
# example for white: "#ffffff", "#ff" or "255 255 255".

# All graphs and meters can be gradients
# For single color graphs leave "mid" and "end" variable empty.
# Use "start" and "end" variables for two color gradient
# Use "start", "mid" and "end" for three color gradient

# Main background, empty for terminal default, need to be empty if you want transparent background
theme[main_bg]=""

# Main text color
theme[main_fg]="#eee0d5"

# Title color for boxes - accent color
theme[title]="#faba73"

# Highlight color for keyboard shortcuts - accent color
theme[hi_fg]="#faba73"

# Background color of selected item in processes box - muted surface, not vibrant
theme[selected_bg]="#251e17"

# Foreground color of selected item in processes box - normal foreground
theme[selected_fg]="#eee0d5"

# Color of inactive/disabled text
theme[inactive_fg]="#9d8e81"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#becc9c"

# Cpu box outline color - subtle
theme[cpu_box]="#50453a"

# Memory/disks box outline color
theme[mem_box]="#50453a"

# Net up/down box outline color
theme[net_box]="#50453a"

# Processes box outline color
theme[proc_box]="#50453a"

# Box divider line and small boxes line color
theme[div_line]="#50453a"

# Temperature graph colors
theme[temp_start]="#becc9c"
theme[temp_mid]="#faba73"
theme[temp_end]="#ffb4ab"

# CPU graph colors
theme[cpu_start]="#faba73"
theme[cpu_mid]="#e0c1a3"
theme[cpu_end]="#becc9c"

# Mem/Disk free meter
theme[free_start]="#becc9c"
theme[free_mid]=""
theme[free_end]="#becc9c"

# Mem/Disk cached meter
theme[cached_start]="#e0c1a3"
theme[cached_mid]=""
theme[cached_end]="#e0c1a3"

# Mem/Disk available meter
theme[available_start]="#faba73"
theme[available_mid]=""
theme[available_end]="#faba73"

# Mem/Disk used meter
theme[used_start]="#ffb4ab"
theme[used_mid]=""
theme[used_end]="#ffb4ab"

# Download graph colors
theme[download_start]="#becc9c"
theme[download_mid]="#faba73"
theme[download_end]="#e0c1a3"

# Upload graph colors
theme[upload_start]="#e0c1a3"
theme[upload_mid]="#faba73"
theme[upload_end]="#becc9c"

# Process box color gradient for threads, mem and cpu usage
theme[process_start]="#becc9c"
theme[process_mid]="#faba73"
theme[process_end]="#ffb4ab"
